<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Signer Examples"
        android:textSize="22sp"
        android:textStyle="bold"
        android:paddingBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Default Vault vs Custom Key Storage via Altude.send()"
        android:textSize="13sp"
        android:alpha="0.6"
        android:paddingBottom="16dp" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── APPROACH A: Default Vault ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Approach A – Default Vault"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Keys in Android Keystore · biometric on every tx · recommended"
                    android:textSize="12sp"
                    android:alpha="0.6"
                    android:paddingBottom="12dp" />

                <Button
                    android:id="@+id/vaultInitButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Init — AltudeGasStation.init(context, apiKey)"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/vaultSendButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Send — Altude.send(options)"
                    android:enabled="false" />

            </LinearLayout>

            <!-- ── APPROACH B: Custom Key Storage ────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Approach B – Custom Key Storage"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your own TransactionSigner · no passkey · instant signing"
                    android:textSize="12sp"
                    android:alpha="0.6"
                    android:paddingBottom="12dp" />

                <Button
                    android:id="@+id/customInitButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Init — InitOptions.custom(mySigner)"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/customSendButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Send (global) — Altude.send(options)"
                    android:enabled="false"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/customSendPerCallButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Send (per-call) — Altude.send(options, signer = mySigner)"
                    android:enabled="false" />

            </LinearLayout>

            <!-- ── Status ─────────────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ready."
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>

