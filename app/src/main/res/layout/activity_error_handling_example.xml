<?xml version="1.0" encoding="utf-8"?>
<!-- Error Handling Example Layout -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Error Handling Examples"
                android:textSize="24sp"
                android:textStyle="bold"
                android:paddingBottom="16dp" />

            <TextView
                android:id="@+id/descriptionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Real vault errors triggered by actual SDK calls"
                android:textSize="14sp"
                android:alpha="0.7"
                android:paddingBottom="24dp" />

            <!-- Error Code Display -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Error Code:"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/errorCodeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="(none yet)"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textColor="@android:color/holo_red_dark" />

            </LinearLayout>

            <!-- Status and Remediation Display -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Message &amp; Recovery:"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    style="?android:attr/progressBarStyleHorizontal" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select an error scenario to see recovery instructions."
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <!-- Error Types Reference -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Error Code Reference:"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:paddingBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔐 VAULT-0201 — Biometric Not Available\nUser has no fingerprint/face/PIN enrolled"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.3"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🚨 VAULT-0202 — Biometric Invalidated\nUser changed fingerprints/face — keys unrecoverable"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.3"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="❌ VAULT-0203/0205 — Auth Failed / Cancelled\nWrong biometric or user tapped Cancel (retryable)"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.3"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔒 VAULT-0401 — Vault Locked\nAltudeGasStation.init() was never called"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.3"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💾 VAULT-0101 — Init / Storage Failed\nDisk full, no write permission, keystore unavailable"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Action Buttons -->
    <Button
        android:id="@+id/testButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Run Scenario"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/clearButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="⚠️ Clear Vault Data"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

</LinearLayout>
