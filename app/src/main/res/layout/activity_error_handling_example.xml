<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Error Handling Examples"
                android:textSize="24sp"
                android:textStyle="bold"
                android:paddingBottom="16dp" />

            <TextView
                android:id="@+id/descriptionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Learn how to handle Vault errors and recover gracefully"
                android:textSize="14sp"
                android:opacity="0.7"
                android:paddingBottom="24dp" />

            <!-- Error Code Display -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_background"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Error Code:"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/errorCodeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="(none yet)"
                    android:textSize="12sp"
                    android:textMonospace="true"
                    android:textColor="@android:color/holo_red_dark" />

            </LinearLayout>

            <!-- Status and Remediation Display -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_background"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Message & Recovery:"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select an error scenario to see recovery instructions."
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.5" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    style="?android:attr/progressBarStyleHorizontal" />

            </LinearLayout>

            <!-- Error Types Guide -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_background"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Common Error Scenarios:"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:paddingBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔐 VAULT-0201: Biometric Not Available"
                        android:textSize="11sp"
                        android:lineSpacingMultiplier="1.3" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="User hasn't enrolled fingerprint/face/PIN"
                        android:textSize="10sp"
                        android:opacity="0.7" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🚨 VAULT-0202: Biometric Invalidated"
                        android:textSize="11sp"
                        android:lineSpacingMultiplier="1.3" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="User changed fingerprints or face (keys unrecoverable)"
                        android:textSize="10sp"
                        android:opacity="0.7" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="❌ VAULT-0203: Authentication Failed"
                        android:textSize="11sp"
                        android:lineSpacingMultiplier="1.3" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Wrong fingerprint/face or cancelled prompt (transient)"
                        android:textSize="10sp"
                        android:opacity="0.7" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔒 VAULT-0401: Vault Locked"
                        android:textSize="11sp"
                        android:lineSpacingMultiplier="1.3" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Vault not initialized (call AltudeGasStation.init())"
                        android:textSize="10sp"
                        android:opacity="0.7" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⏱️ VAULT-0402: Session Expired"
                        android:textSize="11sp"
                        android:lineSpacingMultiplier="1.3" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Session TTL exceeded in session-based mode (automatic re-prompt)"
                        android:textSize="10sp"
                        android:opacity="0.7" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💾 VAULT-0102: Storage Permission Error"
                        android:textSize="11sp"
                        android:lineSpacingMultiplier="1.3" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="App lacks write permission or storage is full"
                        android:textSize="10sp"
                        android:opacity="0.7" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Test Button -->
    <Button
        android:id="@+id/testButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Select Error Scenario"
        android:layout_marginTop="16dp" />

</LinearLayout>
