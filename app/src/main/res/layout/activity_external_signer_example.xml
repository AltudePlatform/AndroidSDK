<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="External Signer Example"
                android:textSize="24sp"
                android:textStyle="bold"
                android:paddingBottom="16dp" />

            <TextView
                android:id="@+id/descriptionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Custom TransactionSigner implementation (no biometric)"
                android:textSize="14sp"
                android:opacity="0.7"
                android:paddingBottom="24dp" />

            <!-- Key Pair Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_background"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Provide Private Key (Hex):"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />

                <EditText
                    android:id="@+id/privateKeyInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="64-character hex string"
                    android:textSize="12sp"
                    android:inputType="text"
                    android:singleLine="true"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/generateKeyButton"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="Generate Test Key Pair" />

            </LinearLayout>

            <!-- Status Display -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_background"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2. Status:"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ready to initialize with custom signer..."
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.5" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    style="?android:attr/progressBarStyleHorizontal" />

            </LinearLayout>

            <!-- Public Key Display -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_background"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="3. Generated Public Key:"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/publicKeyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="(will appear after generation)"
                    android:textSize="11sp"
                    android:textMonospace="true"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <!-- Transaction Details -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_background"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="4. Transaction Details:"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recipient:"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/recipientText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="(auto-generated)"
                        android:textSize="12sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Amount:"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/amountText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0.01 SOL"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:spacing="12dp"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/initButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Initialize with Custom Signer"
            android:layout_marginBottom="8dp"
            android:enabled="false" />

        <Button
            android:id="@+id/transferButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Sign Transfer (No Biometric)"
            android:layout_marginBottom="8dp"
            android:enabled="false" />

        <Button
            android:id="@+id/clearDataButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Clear All Data"
            android:enabled="false"
            android:backgroundTint="@android:color/holo_red_light" />

    </LinearLayout>

</LinearLayout>
